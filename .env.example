# Apify API token (get from https://console.apify.com/account/integrations)
APIFY_TOKEN=your_apify_token_here

# Notion API key (get from https://www.notion.so/my-integrations)
NOTION_API_KEY=your_notion_api_key_here

# Notion parent page ID (where the databases will be created)
# Copy from the Notion page URL: notion.so/Page-Name-XXXXXXXX → XXXXXXXX is the ID
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# Notion database ID for LinkedIn Research
# Filled in automatically by setup_notion_db.py, or set manually after creation
NOTION_RESEARCH_DB_ID=your_research_database_id_here

# Notion database ID for LinkedIn Posts (your own content pipeline)
# Optional — only needed if you want the analyzer to push ideas to a Posts DB
NOTION_POSTS_DB_ID=your_posts_database_id_here

# Path to your creator watchlist markdown file
# Default: ./watchlist.md in the project root
WATCHLIST_PATH=./watchlist.md
